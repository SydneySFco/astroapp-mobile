# Supabase (required for Supabase-first auth flow)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# Reliability runtime binding + replay policy
RELIABILITY_STATE_STORE_DRIVER=supabase
RELIABILITY_STATE_STORE_TABLE=watermark_state
RELIABILITY_REPLAY_MAX_COUNT=8
RELIABILITY_REPLAY_BASE_BACKOFF_MS=500
RELIABILITY_REPLAY_MAX_BACKOFF_MS=60000
RELIABILITY_REPLAY_JITTER_FACTOR=0.2

# Optional legacy API base override (if used in fallback mode)
# API_BASE_URL=https://staging.api.astroapp.example.com
